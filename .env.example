# Fisherboy — entorno. Copiá a .env y ajustá.

# Modo de arranque: sidekick (sin UI, detrás de Escriba) | standalone (UI propia).
APP_MODE=sidekick

# Cola.
REDIS_URL=redis://fisherboy-redis:6379/0

# Anonimización (obligatorio para que el pipeline entregue: fail-closed).
ANONIMAL_URL=http://anonimal:8080
# Token de servicio de Anonimal (ADR-003, v2; hoy Anonimal no exige auth).
ANONIMAL_TOKEN=

# Conversión documental delegada. Requerido en sidekick, opcional en standalone.
ESCRIBA_URL=http://escriba-api:8000

# Rama de extracción por LLM (output_format=json + extract_schema). Proveedor por API
# OpenAI-compatible. Ver ADR-008.
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Modo reversible (Capa 6, ADR-008): clave Fernet (urlsafe base64 de 32 bytes) para
# cifrar la tabla de mapeo, y TTL del mapping_ref. Sin clave: una por proceso (aviso).
REVERSIBLE_KEY=
REVERSIBLE_TTL_S=86400

# Crawling (ADR-007): respetar robots.txt al recorrer multipágina.
RESPECT_ROBOTS=1

# Persistencia Postgres + pgvector (Capa 7, opcional). Vacío = solo Redis.
DATABASE_URL=

# Embeddings / vector store (Capa 7, opcional). Necesita LLM + Postgres+pgvector.
EMBEDDINGS_ENABLED=0
EMBEDDING_MODEL=text-embedding-3-small

# Auth de servicio hacia Escriba (sub-pipeline documental, pendiente del lado de Escriba).
ESCRIBA_TOKEN=

# Política rol×modo. Por defecto usa el privacy_matrix.yaml del repo.
# PRIVACY_MATRIX_PATH=/app/privacy_matrix.yaml

# Límites de fetch (SSRF / costos). Ver ADR-004.
FETCH_TIMEOUT_S=20
FETCH_MAX_BYTES=10485760
FETCH_MAX_REDIRECTS=5

# --- Fetch escalonado: tiers, proxies, anti-CAPTCHA (Capa 3, ADR-006) ---
# Tope de escalado: 0 estático · 1 TLS · 2 stealth · 3 browser.
MAX_FETCH_TIER=3
TIER_CACHE_TTL_S=604800

# Proxies: lista coma/salto-separada (scheme://user:pass@host:port). socks5 ok.
PROXIES=
PROXY_ROTATION=round_robin       # round_robin | random | sticky
PROXY_COOLDOWN_S=120
PROXY_ATTEMPTS=2                 # reintentos rotando proxy dentro de un tier ante bloqueo

# Descarga de video (yt-dlp): defaults del SERVER para YouTube/Vimeo/etc. Lo que el usuario
# cargue en el panel Avanzado (cookies + proxy de ese job) GANA sobre esto; estas vars son
# el fallback global. YouTube bloquea las IPs de datacenter con un "confirmá que no sos bot":
# la salida es darle cookies de una sesión logueada (cuenta SECUNDARIA/descartable) y/o un
# proxy residencial. YT_COOKIES = ruta dentro del contenedor a un cookies.txt Netscape
# (montalo como volumen, ver docker-compose). YT_PROXY = scheme://user:pass@host:port.
YT_COOKIES=
YT_PROXY=
VIDEO_MAX_HEIGHT=1080            # tope de calidad; en Docker (con ffmpeg) muxea hasta acá

# Anti-CAPTCHA: 'none' (solo escalar = prevención) | 'external' (solver por API).
CAPTCHA_SOLVER=none
CAPTCHA_SOLVER_URL=
CAPTCHA_SOLVER_KEY=

# Browser tiers (2/3) stealth. headless=0 (headful) es menos detectable pero necesita
# display/xvfb; en server dejá 1. settle = espera tras cargar; scroll dispara lazy-load.
BROWSER_HEADLESS=1
BROWSER_SETTLE_S=3.5
BROWSER_SCROLL=1
# BROWSER_USER_AGENT=    # UA realista (default: Chrome 124 en Win64)
BROWSER_LOCALE=es-AR

# Cliente HTTP saliente.
ANONIMAL_TIMEOUT_S=180
CALLBACK_TIMEOUT_S=15

# Allowlist de destinos de callback en producción (coma-separada de hosts).
# Vacío = solo bloqueo SSRF. Ver ADR-004 punto 3.
CALLBACK_ALLOWLIST=

# SOLO dev/test local: permitir fetch a destinos privados. NUNCA en producción
# (desactiva TODA la defensa SSRF; el arranque lo avisa ruidosamente). Default 0.
ALLOW_PRIVATE_TARGETS=0

LOG_LEVEL=INFO

# --- Límites anti-DoS (auditoría 2026-06) ---
MAX_JOBS_PER_MIN=60         # rate-limit de admisión por IP (0 = sin límite)
CRAWL_MAX_PAGES=100         # tope DURO de páginas por job (crawl/paginado)
JOB_MAX_TOTAL_BYTES=83886080  # tope de bytes acumulados por job (80 MB; 0 = sin tope)

# --- Auth por rol (espejo de Escriba, ADR-011) ---
# Mismas variables que Escriba: la misma clave sirve en los dos.
# FAIL-CLOSED: sin contraseñas ni API_TOKEN ni opt-in, el servicio RECHAZA todo (401).
# El modo abierto de dev es opt-in EXPLÍCITO (ver FISHERBOY_OPEN_GOD abajo).
SECRET_KEY=                 # clave de firma de sesión (OBLIGATORIA con auth; igual en todos los workers)
GOD_PASSWORD=               # clave del rol dios (todas las armas)
ANGEL_PASSWORD=             # clave del rol ángel (browser/proxy/captura, sin solver)
HUMAN_PASSWORD=             # clave del rol humano (tiers baratos, sin armas caras)
SESSION_TTL_HOURS=12
HUMAN_OPEN=0                # 1 = acceso humano sin login (conversor público acotado)
API_TOKEN=                  # token estático para REST/MCP (automatización)
API_TOKEN_ROLE=angel        # rol que mapea ese token
MCP_ROLE=humano             # techo de rol del servidor MCP (NO se confía en el rol del caller)

# Cookie de sesión: Secure (solo HTTPS) por defecto. En dev local sobre http://127.0.0.1
# poné 0 o el navegador no la mandará. En producción dejalo en 1 (detrás de HTTPS).
COOKIE_SECURE=1

# SOLO dev local: acceso ABIERTO como dios sin login (opt-in explícito y ruidoso).
# NUNCA en producción. Si no lo seteás y no hay contraseñas → 401 (fail-closed).
FISHERBOY_OPEN_GOD=0
